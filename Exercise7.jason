        "id": "616fa8dfb77c4a39",
        "type": "function",
        "z": "e729b5254d6e6fcc",
        "name": "Array Manipulation ($push and $pop)",
        "func": "var filter = { \"device_id\": \"GATEWAY_01\" };\nvar update = {\n    \"$push\": { \"sensors_attached\": \"light_level\" },\n    \"$pop\": { \"active_warnings\": -1 }\n    // -1 removes the first item, 1 removes the last item\n};\nmsg.payload = [filter, update];\nreturn msg;",
